{
  "name": "agora",
  "private": true,
  "type": "module",
  "description": "Ágora — Open Data Intelligence",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "verify": "turbo run lint typecheck",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\""
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": ["onnxruntime-node", "protobufjs", "sharp"]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
