{
  "name": "agora-mcp",
  "version": "0.1.0",
  "description": "MCP server that gives LLMs access to open government data catalogs. Hybrid search, SQL analysis via DuckDB, local embeddings.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./lib": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    }
  },
  "bin": {
    "agora-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "homepage": "https://github.com/idemfede/agora",
  "repository": {
    "type": "git",
    "url": "https://github.com/idemfede/agora",
    "directory": "packages/mcp"
  },
  "keywords": [
    "mcp",
    "open-data",
    "government",
    "llm",
    "duckdb",
    "ckan",
    "model-context-protocol"
  ],
  "dependencies": {
    "@duckdb/node-api": "1.5.0-r.1",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "jschardet": "^3.1.4",
    "vectra": "^0.12.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@agora/sdk": "workspace:*",
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
