# Ágora MCP Server — Environment Variables
# All variables are optional. Defaults shown below.

# Storage: persistent data (metadata cache, FTS indexes, vector store)
# AGORA_DATA_DIR=~/.agora/data

# Storage: downloaded file cache (CSVs, etc.)
# AGORA_CACHE_DIR=~/.agora/cache

# Log level: debug | info | warn | error
# AGORA_LOG_LEVEL=info

# Metadata cache TTL in hours (re-fetch from catalog API after this)
# AGORA_METADATA_TTL_HOURS=24

# Presets: named catalog bundles (comma-separated). See presets.json.
# Available: argentina, latam, english, all
# AGORA_PRESETS=argentina

# Explicit catalog IDs to activate (comma-separated). See catalogs.json.
# Can be combined with presets. If neither is set, defaults to datos-gob-ar.
# AGORA_CATALOGS=datos-gob-ar,datos-gob-cl

# Batch size for embedding generation (higher = faster but more memory)
# AGORA_EMBEDDING_BATCH_SIZE=64

# SQL query timeout in milliseconds (default: 60000, max: 300000)
# AGORA_QUERY_TIMEOUT_MS=60000

# Max file size for download in MB (default: 200). Larger files use DuckDB httpfs streaming.
# AGORA_MAX_FILE_SIZE_MB=200
